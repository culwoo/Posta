rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection (Dashboard Organizers)
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Events collection
    match /events/{eventId} {
      // Anyone can read event info
      allow read: if true;
      // Only the owner can update/delete
      // Note: allow create for authenticated users to create a new event
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Subcollections
      match /reservations/{reservationId} {
        // Guests can create reservations (even anonymously)
        allow create: if true;
        // Guests can read/update their own, Owner can read/update all
        allow read, update: if true; // Permissive read for anonymous verifyToken, needs strict rules later
        allow delete: if request.auth != null; 
      }
      
      match /posts/{postId} {
        // Anyone can read and create posts (guestbook)
        allow read, create: if true;
        // Updating/deleting
        allow update, delete: if request.auth != null;
        
        match /comments/{commentId} {
          allow read, create: if true;
          allow update, delete: if request.auth != null;
        }
      }
      
      match /performers/{performerId} {
        // Performers list
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
