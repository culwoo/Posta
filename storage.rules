rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all files
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Allow authenticated users to upload event posters
    match /events/{eventId}/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Allow ANY user to upload receipt images (no auth required)
    match /receipts/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
